{
  "family": "modern-credit-task",
  "executionRoleArn": "arn:aws:iam::478966647597:role/ecs-task-execution-role-dev",
  "taskRoleArn": "arn:aws:iam::478966647597:role/ecs-task-execution-role-dev",
  "containerDefinitions": [
    {
      "name": "api",
      "image": "<IMAGE_NAME>",
      "portMappings": [
        {
          "containerPort": 8080,
          "hostPort": 8080,
          "protocol": "tcp"
        }
      ],
      "secrets": [
        {
          "name": "NEPTUNE_ENDPOINT",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:478966647597:secret:modern-credit-bridge-7IM1qz:NEPTUNE_ENDPOINT::"
        },
        {
          "name": "SQS_QUEUE_URL",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:478966647597:secret:modern-credit-bridge-7IM1qz:SQS_QUEUE_URL::"
        },
        {
          "name": "AWS_REGION",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:478966647597:secret:modern-credit-bridge-7IM1qz:AWS_REGION::"
        }
      ],
      "environment": [
        {
          "name": "SPRING_PROFILES_ACTIVE",
          "value": "prod"
        }
      ],
      "essential": true,
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/modern-credit-task",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ],
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "networkMode": "awsvpc",
  "cpu": "256",
  "memory": "512"
}