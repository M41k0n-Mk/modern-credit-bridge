{
  "family": "modern-credit-task",
  "containerDefinitions": [
    {
      "name": "api",
      "image": "<IMAGE_NAME>",
      "portMappings": [
        {
          "containerPort": 8080,
          "hostPort": 8080,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "NEPTUNE_ENDPOINT", "value": "SEU_ENDPOINT_AQUI" },
        { "name": "SQS_QUEUE_URL", "value": "SUA_URL_SQS_AQUI" },
        { "name": "SPRING_PROFILES_ACTIVE", "value": "prod" }
      ],
      "essential": true
    }
  ],
  "requiresCompatibilities": ["FARGATE"],
  "networkMode": "awsvpc",
  "cpu": "256",
  "memory": "512"
}