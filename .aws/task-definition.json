{
  "family": "modern-credit-task",
  "containerDefinitions": [
    {
      "name": "api",
      "image": "<IMAGE_NAME>",
      "portMappings": [
        { "containerPort": 8080, "hostPort": 8080, "protocol": "tcp" }
      ],
      "secrets": [
        { "name": "NEPTUNE_ENDPOINT", "valueFrom": "arn:aws:secretsmanager:us-east-1:478966647597:secret:modern-credit-bridge-7IM1qz:NEPTUNE_ENDPOINT::" },
        { "name": "SQS_QUEUE_URL",    "valueFrom": "arn:aws:secretsmanager:us-east-1:478966647597:secret:modern-credit-bridge-7IM1qz:SQS_QUEUE_URL::" },
        { "name": "AWS_REGION",       "valueFrom": "arn:aws:secretsmanager:us-east-1:478966647597:secret:modern-credit-bridge-7IM1qz:AWS_REGION::" }
      ],
      "environment": [
        { "name": "SPRING_PROFILES_ACTIVE", "value": "prod" }
      ],
      "essential": true
    }
  ],
  "requiresCompatibilities": ["FARGATE"],
  "networkMode": "awsvpc",
  "cpu": "256",
  "memory": "512"
}